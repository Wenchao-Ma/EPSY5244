library(psych)
library(CTT)
library(tidyverse)
library(corrplot)
library(knitr)
# Load built-in dataset
data("bfi", package = "psych")
# Select Agreeableness items
A_items <- bfi %>%
select(A1:A5)
# Keep complete cases for simpler demonstration
A_complete <- A_items %>%
drop_na()
dim(A_complete)
head(A_complete)
# Responses are on a 1-6 scale, so reverse-score with 7 - x
A_keyed <- A_complete %>%
mutate(A1 = 7 - A1)
head(A_keyed)
# Alpha
alpha_fit <- psych::alpha(A_keyed)
alpha_fit$total$raw_alpha
# Omega (single-factor approximation for this 5-item example)
omega_fit <- psych::omega(A_keyed, nfactors = 1)
omega_fit$omega.tot
alpha_fit$item.stats
alpha_fit <- psych::alpha(A_keyed)
alpha_fit$item.stats
alpha_fit$alpha.drop
alpha_fit
alpha_fit$alpha.drop
library(CTT)
itemanalysis <- CTT::itemAnalysis(A_keyed)
itemanalysis$itemReport
corrplot(R_items, method = "number", type = "lower")
R_items <- cor(A_keyed)
round(R_items, 2)
corrplot(R_items, method = "number", type = "lower")
likert::likert(A_keyed)
